rules_version = '2';

// CampusKart Firestore security rules.
// Paste these into: Firebase Console → Firestore Database → Rules → Publish.
//
// Summary:
//   - Anyone (signed-in) can read colleges + products + writingPosts.
//   - Users can only create/edit/delete their own products, writing posts,
//     reports, and user profile.
//   - Conversations + messages: only the 2 participants can read/write.
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────
    // A user doc is keyed by the Firebase Auth uid.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;
    }

    // ── Colleges ─────────────────────────────────────────────────────────
    match /colleges/{collegeId} {
      allow read: if true;
      allow write: if false; // managed by the seed script (Admin SDK bypasses rules)
    }

    // ── Products (marketplace listings) ──────────────────────────────────
    match /products/{productId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.sellerId == request.auth.uid;
    }

    // ── Writing Hub posts ────────────────────────────────────────────────
    match /writingPosts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;
    }

    // ── Conversations + Messages (real-time chat) ────────────────────────
    // Conversations store participants as an array of Firebase uids.
    match /conversations/{convId} {
      // Only participants can read the conversation doc.
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      // Anyone signed-in can create a conversation (the server-side API
      // validates that the creator is a participant before writing).
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      // Only participants can update (e.g. lastMessage snapshot).
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.participants;

      // Messages subcollection — only conversation participants can read/write.
      match /messages/{messageId} {
        allow read: if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if request.auth != null
                      && request.auth.uid ==
                         request.resource.data.senderId
                      && request.auth.uid in
                         get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow update: if request.auth != null
                      && request.auth.uid in
                         get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow delete: if false;
      }
    }

    // ── Reports ──────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if false; // admin-only
      allow create: if request.auth != null
                    && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
